def clear():
    print("\033[2J\033[H", end="")

def logo():
    clear()
    print(LOGO)


# ── Dep checks ──────────────────────────────────────────

def _install_yay():
    warn("yay: installing from AUR …")
    tmp = Path("/tmp/yay-build")
    shutil.rmtree(tmp, ignore_errors=True)
    tmp.mkdir(parents=True, exist_ok=True)
    run("git", "clone", "https://aur.archlinux.org/yay.git", str(tmp))
    run("makepkg", "-si", "--noconfirm", cwd=str(tmp))
    shutil.rmtree(tmp, ignore_errors=True)
    ok("yay: installed")


def ensure_deps():
    if SKIP_PACKAGES:
        for cmd in ("git", "python3", "fzf"):
            if has(cmd):
                ok(f"{cmd}: found")
            else:
                warn(f"{cmd}: missing; package install skipped by ARCHX_SKIP_PACKAGES=1")
        return

    for cmd, pkg in [("wget", "wget"), ("git", "git"), ("fzf", "fzf"), ("python3", "python")]:
        if has(cmd):
            ok(f"{cmd}: found")
        else:
            warn(f"{cmd}: installing …")
            run("pacman", "-S", "--needed", "--noconfirm", pkg, sudo=True)
            ok(f"{cmd}: installed")

    if not has("yay"):
        _install_yay()


# ── Installers ──────────────────────────────────────────

def install_samba():
    run("systemctl", "enable", "smb.service", sudo=True)
    run("systemctl", "enable", "nmb.service", sudo=True)
    warn("Setting samba password for current user")
    user = os.environ.get("USER") or run_allowfail("whoami", capture_output=True, text=True).stdout.strip() or "root"
    run("smbpasswd", "-a", user, sudo=True)


def install_remap():
    run("yay", "-S", "--quiet", "--noconfirm", "--needed", "input-remapper-git")
    run("systemctl", "restart", "input-remapper", sudo=True)
    run("systemctl", "enable", "input-remapper", sudo=True)
    line = "input-remapper-control --command autoload &\n"
    if AUTOSTART.exists():
        if line.strip() not in AUTOSTART.read_text():
            AUTOSTART.write_text(AUTOSTART.read_text() + line)
    else:
        AUTOSTART.parent.mkdir(parents=True, exist_ok=True)
        AUTOSTART.write_text(line)


def install_wine():
    if not has("yay"):
        _install_yay()
    run("yay", "-S", "--noconfirm", "--needed", "dxvk-bin")
    run("pacman", "-S", "--needed", "--noconfirm",
        "wine", "winetricks", "wine-mono", sudo=True)
    print(f"\n  {YELLOW}→ In Drives → Show dotfiles = true")
    print("  → Desktop Integration → Theme = null")
    print(f"  → WinRt theme → Dark{RESET}\n")
    run("winecfg")

    reg = "Windows Registry Editor Version 5.00\n\n"
    reg += "[HKEY_CURRENT_USER\\Control Panel\\Colors]\n"
    colors = {
        "ActiveBorder": "1 1 1", "ActiveTitle": "255 255 255",
        "AppWorkSpace": "1 1 1", "Background": "1 1 1",
        "ButtonAlternateFace": "1 1 1", "ButtonDkShadow": "1 1 1",
        "ButtonFace": "1 1 1", "ButtonHilight": "255 255 255",
        "ButtonLight": "255 255 255", "ButtonShadow": "1 1 1",
        "ButtonText": "255 255 255", "GrayText": "255 255 255",
        "Hilight": "255 255 255", "HilightText": "1 1 1",
        "HotTrackingColor": "255 255 255", "InactiveBorder": "1 1 1",
        "InactiveTitle": "255 255 255", "InactiveTitleText": "1 1 1",
        "InfoText": "255 255 255", "InfoWindow": "1 1 1",
        "Menu": "1 1 1", "MenuBar": "1 1 1",
        "MenuHilight": "255 255 255", "MenuText": "255 255 255",
        "Scrollbar": "1 1 1", "TitleText": "255 255 255",
        "Window": "1 1 1", "WindowFrame": "255 255 255",
        "WindowText": "255 255 255",
    }
    for k, v in colors.items():
        reg += f'"{k}"="{v}"\n'

    regfile = Path("/tmp/wine_theme.reg")
    regfile.write_text(reg)
    run("wine", "regedit", str(regfile))
    regfile.unlink(missing_ok=True)

    gpu = run_allowfail("lspci", capture_output=True, text=True).stdout
    gpu_pkgs = []
    if "NVIDIA" in gpu or "GeForce" in gpu:
        gpu_pkgs = ["nvidia-dkms", "nvidia-utils", "lib32-nvidia-utils", "nvidia-settings", "vulkan-icd-loader", "lib32-vulkan-icd-loader"]
    elif "Radeon" in gpu or "AMD" in gpu:
        gpu_pkgs = ["lib32-mesa", "vulkan-radeon", "lib32-vulkan-radeon", "vulkan-icd-loader", "lib32-vulkan-icd-loader"]
    elif "Intel" in gpu and ("UHD" in gpu or "Integrated" in gpu):
        gpu_pkgs = ["lib32-mesa", "vulkan-intel", "lib32-vulkan-intel", "vulkan-icd-loader", "lib32-vulkan-icd-loader"]
    if gpu_pkgs:
        run("pacman", "-S", "--needed", "--noconfirm", *gpu_pkgs, sudo=True)

    run("wineboot")


def install_printers():
    run("pacman", "-S", "--needed", "--noconfirm",
        "cups", "cups-pdf", "ghostscript", "gsfonts", "gutenprint",
        "gtk3-print-backends", "libcups", "system-config-printer", sudo=True)
    run("systemctl", "enable", "cups.service", sudo=True)
    run("systemctl", "start", "cups.service", sudo=True)


def install_ctpv():
    run("bash", "-c", "curl -s https://raw.githubusercontent.com/X3ric/ctpv/master/install | bash")


# ── Git helpers ─────────────────────────────────────────

def _git_dir():
    return f"--git-dir={CACHE / '.git'}"

def _git_fetch():
    if not (CACHE / ".git").exists():
        return False
    run_allowfail("git", _git_dir(), "fetch", "--quiet")
    return True

def _git_behind_count():
    r = run_allowfail("git", _git_dir(), "rev-list", "HEAD...origin/main", "--count",
                      capture_output=True, text=True)
    return int(r.stdout.strip() or "0")

def _git_last_log():
    r = run_allowfail("git", _git_dir(), "log", "--pretty=format:%B", "-1", "origin/main",
                      capture_output=True, text=True)
    return r.stdout.strip()


# ── Updates ─────────────────────────────────────────────

def check_updates():
    if not _git_fetch():
        return False
    count = _git_behind_count()
    if count > 0:
        warn(f"Dotfiles update: {_git_last_log()}")
        return True
    return False


def check_updates_notify():
    if not _git_fetch():
        return
    if _git_behind_count() > 0:
        msg = _git_last_log()
        print(f"Update: {msg}")
        run_allowfail("notify-send", "Dotfiles Update", f"archx > update\n{msg}")


def _fetch_pkg_list(url, stop_marker=None):
    with urllib.request.urlopen(url) as r:
        lines = r.read().decode().splitlines()
    pkgs = []
    for line in lines:
        line = line.split("#", 1)[0].strip()
        if not line:
            continue
        if stop_marker and stop_marker in line:
            break
        pkgs.append(line)
    return pkgs


def _install_pkg_list(url, stop_marker, runner, label):
    spinner = Spinner(label)
    spinner.start()
    try:
        for pkg in _fetch_pkg_list(url, stop_marker):
            runner(pkg)
        spinner.stop(True)
    except Exception:
        spinner.stop(False)
        raise


def _clone_usr_repo():
    # Explicit ARCHX_USR_REF is tried first. If it fails, fall back to the repo
    # default branch, then main, then master.
    shutil.rmtree(CACHE, ignore_errors=True)
    attempts = []
    if USR_REF:
        attempts.append(["git", "clone", "--depth", "1", "--branch", USR_REF, USR_REPO, str(CACHE)])
    attempts.append(["git", "clone", "--depth", "1", USR_REPO, str(CACHE)])
    attempts.append(["git", "clone", "--depth", "1", "--branch", "main", USR_REPO, str(CACHE)])
    attempts.append(["git", "clone", "--depth", "1", "--branch", "master", USR_REPO, str(CACHE)])

    last = None
    for cmd in attempts:
        shutil.rmtree(CACHE, ignore_errors=True)
        r = run_allowfail(*cmd, capture_output=True, text=True)
        if r.returncode == 0:
            ok("usr repo cloned")
            return
        last = (r.stderr or r.stdout or "clone failed").strip()
        warn(f"clone attempt failed: {' '.join(cmd[1:5])}")
    raise RuntimeError(last or "failed to clone usr repo")


def _sync_usr_tree():
    copied = 0
    for f in sorted(CACHE.rglob("*")):
        if f.is_dir() or _skip(f):
            continue
        rel = f.relative_to(CACHE)
        target = HOME / rel
        target.parent.mkdir(parents=True, exist_ok=True)
        run("cp", "-rpa", str(f), str(target))
        copied += 1
    ok(f"synced {copied} usr files")


def _write_file(path, text, mode=None):
    path = Path(path).expanduser()
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text)
    if mode is not None:
        path.chmod(mode)


def setup_shell_and_tty1_autostart():
    start_script = BIN / "start-hyprland"
    _write_file(start_script, '''#!/usr/bin/env bash
set -euo pipefail

export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=Hyprland
export XDG_SESSION_DESKTOP=Hyprland
export GDK_BACKEND=wayland,x11
export QT_QPA_PLATFORM='wayland;xcb'
export MOZ_ENABLE_WAYLAND=1
export XCURSOR_THEME="${XCURSOR_THEME:-cz-Hickson-Black}"
export XCURSOR_SIZE="${XCURSOR_SIZE:-24}"
export HYPRCURSOR_THEME="${HYPRCURSOR_THEME:-cz-Hickson-Black}"
export HYPRCURSOR_SIZE="${HYPRCURSOR_SIZE:-24}"

if command -v uwsm >/dev/null 2>&1 && uwsm check may-start >/dev/null 2>&1; then
    exec systemd-cat -t uwsm_start uwsm start hyprland.desktop
fi

if command -v dbus-run-session >/dev/null 2>&1; then
    exec dbus-run-session Hyprland
fi
exec Hyprland
''', 0o755)
    _write_file(BIN / "archx-start-hyprland", '#!/usr/bin/env bash\nexec start-hyprland "$@"\n', 0o755)

    autostart = '''# ArchX tty1 Hyprland autostart. Safe for bash/zsh login shells.
archx_start_hyprland_tty1() {
    [ -z "${SSH_TTY:-}" ] || return 0
    [ -z "${DISPLAY:-}" ] || return 0
    [ -z "${WAYLAND_DISPLAY:-}" ] || return 0
    [ "$(tty 2>/dev/null)" = "/dev/tty1" ] || return 0
    command -v start-hyprland >/dev/null 2>&1 || return 0
    exec start-hyprland
}
archx_start_hyprland_tty1
'''
    profile = '''# ArchX user environment
export PATH="$HOME/.local/share/bin:$HOME/.local/bin:$PATH"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export GTK_THEME="${GTK_THEME:-darkarch}"
export XCURSOR_THEME="${XCURSOR_THEME:-cz-Hickson-Black}"
export XCURSOR_SIZE="${XCURSOR_SIZE:-24}"
export HYPRCURSOR_THEME="${HYPRCURSOR_THEME:-cz-Hickson-Black}"
export HYPRCURSOR_SIZE="${HYPRCURSOR_SIZE:-24}"
export MOZ_ENABLE_WAYLAND=1
'''
    _write_file(HOME / ".profile", profile + "\n" + autostart)
    _write_file(HOME / ".bash_profile", '[ -f "$HOME/.profile" ] && . "$HOME/.profile"\n')
    _write_file(HOME / ".zshenv", ARCHX_ZSHENV_TEXT)
    _write_file(HOME / ".zshrc", ARCHX_HOME_ZSHRC)
    _write_file(HOME / ".local/zsh/.zprofile", '[ -f "$HOME/.profile" ] && source "$HOME/.profile"\n')
    _write_file(HOME / ".config/zsh/.zshenv", ARCHX_ZSHENV_TEXT)
    _write_file(HOME / ".config/zsh/.zshrc", ARCHX_COMPAT_ZSHRC)
    _write_file(HOME / ".config/zsh/.zprofile", ARCHX_COMPAT_ZPROFILE)

    # Keep zsh loading the real ArchX config from every login path.
    # This intentionally uses tee instead of a temp copy so sudo/non-root firstboot behaves reliably.
    run_allowfail("mkdir", "-p", "/etc/zsh", sudo=True)
    r = run_allowfail("tee", "/etc/zsh/zshenv", sudo=True, input=ARCHX_ZSHENV_TEXT, text=True,
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if r.returncode == 0:
        ok("global zshenv points to ~/.local/zsh")
    else:
        warn("could not write /etc/zsh/zshenv; user zshenv fallback is installed")
    ok("shell profiles and tty1 Hyprland autostart configured")



def apply_default_wallpaper_and_terminal():
    wal_cache = HOME / ".cache/wal"
    wal_cache.mkdir(parents=True, exist_ok=True)
    default_wall = HOME / "Pictures/Wallpapers/Nature/Nature.png"
    if not default_wall.exists():
        candidates = list((HOME / "Pictures/Wallpapers").glob("**/*"))
        candidates = [p for p in candidates if p.suffix.lower() in (".jpg", ".jpeg", ".png", ".webp")]
        default_wall = candidates[0] if candidates else default_wall
    if default_wall.exists():
        (wal_cache / "wal").write_text(str(default_wall) + "\n")
    else:
        (wal_cache / "wal").write_text("$HOME/Pictures/Wallpapers/Nature/Nature.png\n")

    colors = ['#0b0b0b', '#48534A', '#516D55', '#5B5B69', '#658B5F', '#564F96', '#645B97', '#c0acd1', '#867892', '#48534A', '#516D55', '#5B5B69', '#658B5F', '#564F96', '#645B97', '#c0acd1']
    (wal_cache / "colors").write_text("\n".join(colors) + "\n")
    kitty_text = 'foreground         #c0acd1\nbackground         #0b0b0b\nbackground_opacity 0.92\ncursor             #c0acd1\n\nactive_tab_foreground     #0b0b0b\nactive_tab_background     #c0acd1\ninactive_tab_foreground   #c0acd1\ninactive_tab_background   #0b0b0b\n\nactive_border_color   #c0acd1\ninactive_border_color #0b0b0b\nbell_border_color     #48534A\n\ncolor0       #0b0b0b\ncolor8       #867892\ncolor1       #48534A\ncolor9       #48534A\ncolor2       #516D55\ncolor10      #516D55\ncolor3       #5B5B69\ncolor11      #5B5B69\ncolor4       #658B5F\ncolor12      #658B5F\ncolor5       #564F96\ncolor13      #564F96\ncolor6       #645B97\ncolor14      #645B97\ncolor7       #c0acd1\ncolor15      #c0acd1\n'
    waybar_text = '@define-color foreground #c0acd1;\n@define-color background #0b0b0b;\n@define-color cursor #c0acd1;\n\n@define-color color0 #0b0b0b;\n@define-color color1 #48534A;\n@define-color color2 #516D55;\n@define-color color3 #5B5B69;\n@define-color color4 #658B5F;\n@define-color color5 #564F96;\n@define-color color6 #645B97;\n@define-color color7 #c0acd1;\n@define-color color8 #867892;\n@define-color color9 #48534A;\n@define-color color10 #516D55;\n@define-color color11 #5B5B69;\n@define-color color12 #658B5F;\n@define-color color13 #564F96;\n@define-color color14 #645B97;\n@define-color color15 #c0acd1;\n'
    css_text = ':root {\n    --color0: #0b0b0b;\n    --color1: #48534A;\n    --color2: #516D55;\n    --color3: #5B5B69;\n    --color4: #658B5F;\n    --color5: #564F96;\n    --color6: #645B97;\n    --color7: #c0acd1;\n    --color8: #867892;\n    --color9: #48534A;\n    --color10: #516D55;\n    --color11: #5B5B69;\n    --color12: #658B5F;\n    --color13: #564F96;\n    --color14: #645B97;\n    --color15: #c0acd1;\n    --foreground: #c0acd1;\n    --background: #0b0b0b;\n}\n'
    (wal_cache / "colors-kitty.conf").write_text(kitty_text)
    (wal_cache / "colors-waybar.css").write_text(waybar_text)
    (wal_cache / "colors.css").write_text(css_text)
    fzf_text = r"""# Generated by walset/archx. Safe for zsh/bash source.
if [ -z "${ARCHX_FZF_COLORS_LOADED:-}" ]; then
  export ARCHX_FZF_COLORS_LOADED=1
  export FZF_DEFAULT_OPTS="--height=40% --layout=reverse --border=rounded --prompt=❯  --pointer=❯ --marker=+ --color=fg:#c0acd1,bg:#0b0b0b,fg+:#c0acd1,bg+:#48534A,hl:#658B5F,hl+:#658B5F,info:#645B97,prompt:#516D55,pointer:#c0acd1,marker:#564F96,spinner:#658B5F,header:#5B5B69,border:#867892,gutter:#0b0b0b ${FZF_DEFAULT_OPTS:-}"
  export FZF_CTRL_R_OPTS="--preview 'echo {}' --preview-window=down:3:hidden:wrap --bind 'ctrl-/:toggle-preview' ${FZF_CTRL_R_OPTS:-}"
  export FZF_CTRL_T_OPTS="--preview 'fzf-preview {} 2>/dev/null || file -- {}' --preview-window=right:60%:wrap ${FZF_CTRL_T_OPTS:-}"
  export FZF_ALT_C_OPTS="--preview 'ls -la --color=always {} 2>/dev/null | head -80' --preview-window=right:60%:wrap ${FZF_ALT_C_OPTS:-}"
