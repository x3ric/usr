#logout { background-color: rgba(91, 91, 105, 0.55); }
#suspend { background-color: rgba(101, 139, 95, 0.55); }
#hibernate { background-color: rgba(86, 79, 150, 0.55); }
#shutdown { background-color: rgba(100, 91, 151, 0.55); }
#reboot { background-color: rgba(134, 120, 146, 0.55); }
""")
    if has("gtkset"):
        run_allowfail("gtkset", stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    ok("default Nature wallpaper, terminal colors, and wlogout theme prepared")
def apply_gtk_theme():
    for d in (HOME / ".config/gtk-2.0", HOME / ".config/gtk-3.0", HOME / ".config/gtk-4.0"):
        d.mkdir(parents=True, exist_ok=True)
        _write_file(d / "settings.ini", '''[Settings]
gtk-theme-name=darkarch
gtk-icon-theme-name=Papirus
gtk-font-name=Hack 10
gtk-cursor-theme-name=cz-Hickson-Black
gtk-cursor-theme-size=24
gtk-toolbar-style=GTK_TOOLBAR_BOTH
gtk-toolbar-icon-size=GTK_ICON_SIZE_SMALL_TOOLBAR
gtk-button-images=1
gtk-menu-images=1
gtk-enable-event-sounds=1
gtk-enable-input-feedback-sounds=0
gtk-xft-antialias=1
gtk-xft-hinting=1
gtk-xft-hintstyle=hintslight
gtk-xft-rgba=rgb
gtk-application-prefer-dark-theme=1
''')

    _write_file(HOME / ".gtkrc-2.0", '''gtk-theme-name="darkarch"
gtk-icon-theme-name="Papirus"
gtk-font-name="Hack 10"
gtk-cursor-theme-name="cz-Hickson-Black"
gtk-cursor-theme-size=24
gtk-toolbar-style=GTK_TOOLBAR_BOTH
gtk-toolbar-icon-size=GTK_ICON_SIZE_SMALL_TOOLBAR
gtk-button-images=1
gtk-menu-images=1
gtk-enable-event-sounds=1
gtk-enable-input-feedback-sounds=0
gtk-xft-antialias=1
gtk-xft-hinting=1
gtk-xft-hintstyle="hintslight"
gtk-xft-rgba="rgb"
''')

    _write_file(HOME / ".config/xsettingsd/xsettingsd.conf", '''Net/ThemeName "darkarch"
Net/IconThemeName "Papirus"
Gtk/CursorThemeName "cz-Hickson-Black"
Gtk/CursorThemeSize 24
Net/EnableEventSounds 1
EnableInputFeedbackSounds 0
Xft/Antialias 1
Xft/Hinting 1
Xft/HintStyle "hintslight"
Xft/RGBA "rgb"
''')

    _write_file(HOME / ".config/environment.d/90-archx-theme.conf", '''PATH=%h/.local/share/bin:%h/.local/bin:${PATH}
GTK_THEME=darkarch
XCURSOR_THEME=cz-Hickson-Black
XCURSOR_SIZE=24
HYPRCURSOR_THEME=cz-Hickson-Black
HYPRCURSOR_SIZE=24
MOZ_ENABLE_WAYLAND=1
''')

    for cmd in [
        ("gsettings", "set", "org.gnome.desktop.interface", "gtk-theme", "darkarch"),
        ("gsettings", "set", "org.gnome.desktop.interface", "icon-theme", "Papirus"),
        ("gsettings", "set", "org.gnome.desktop.interface", "cursor-theme", "cz-Hickson-Black"),
        ("gsettings", "set", "org.gnome.desktop.interface", "color-scheme", "prefer-dark"),
    ]:
        run_allowfail(*cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    run_allowfail("gtk-update-icon-cache", "-f", "-t", str(HOME / ".icons/Papirus"), stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if has("papirus-folders"):
        run_allowfail("papirus-folders", "-C", "green", stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if has("papirus-folders-autocolor"):
        run_allowfail("papirus-folders-autocolor", stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if has("gtkset"):
        run_allowfail("gtkset", stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    ok("GTK theme/icon settings applied")



def ensure_zsh_login_shell():
    zsh = shutil.which("zsh") or "/bin/zsh"
    user = os.environ.get("SUDO_USER") or os.environ.get("USER") or getpass.getuser()
    if not Path(zsh).exists():
        warn("zsh missing; login shell unchanged")
        return
    current = run_allowfail("getent", "passwd", user, capture_output=True, text=True).stdout.strip().split(":")
    if len(current) >= 7 and current[-1] == zsh:
        ok("login shell already zsh")
        return
    run_allowfail("chsh", "-s", zsh, user, sudo=True)
    current = run_allowfail("getent", "passwd", user, capture_output=True, text=True).stdout.strip().split(":")
    if len(current) >= 7 and current[-1] == zsh:
        ok("login shell set to zsh")
    else:
        warn("could not change login shell automatically; kitty still starts zsh")

def post_apply():
    setup_shell_and_tty1_autostart()
    ensure_zsh_login_shell()
    apply_default_wallpaper_and_terminal()
    apply_gtk_theme()
    run_allowfail("hyprctl", "reload", stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    run_allowfail("pkill", "-SIGUSR2", "waybar", stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def update_config():
    logo()
    ARCHX_CACHE.mkdir(parents=True, exist_ok=True)
    ts = time.strftime("%Y%m%d_%H%M%S")
    diff_file = ARCHX_CACHE / f"diff-{ts}"
    warn(f"This will sync dotfiles from {USR_REPO}")
    warn(f"Diffs saved to {diff_file}")
    if SKIP_PACKAGES:
        warn("ARCHX_SKIP_PACKAGES=1: package install skipped; applying configs only")
    if not AUTO_YES and input("  Continue? [y/N]: ").strip().lower() != "y":
        return

    if not ensure_network():
        return

    if not SKIP_PACKAGES:
        _install_pkg_list(
            PKG_OFFICIAL, "--END OF MINIMAL INSTALL--",
            lambda p: run("pacman", "-S", "--noconfirm", "--needed", p, sudo=True),
            "Installing official packages",
        )
        _install_pkg_list(
            PKG_AUR, "--END OF MINIMAL INSTALL--",
            lambda p: run("yay", "-S", "--quiet", "--noconfirm", "--needed", p),
            "Installing AUR packages",
        )
    else:
        ok("package phase skipped")

    if not SKIP_PACKAGES and not has("ctpv-x"):
        install_ctpv()
        ok("ctpv installed")

    if has("desktop-hide"):
        run_allowfail("desktop-hide")

    if CACHE.exists():
        ok(f"Saving diffs to {diff_file}")
        with open(diff_file, "w") as df:
            for f in sorted(CACHE.rglob("*")):
                if f.is_dir() or _skip(f):
                    continue
                rel = f.relative_to(CACHE)
                target = HOME / rel
                if target.exists():
                    r = run_allowfail("diff", "-uN", str(f), str(target), capture_output=True, text=True)
                    if r.stdout:
                        df.write(r.stdout)
                else:
                    df.write(f"File not found: {rel}\n")

    CACHE.parent.mkdir(parents=True, exist_ok=True)
    if USR_DIR:
        src = Path(USR_DIR).expanduser()
        if not src.exists():
            raise FileNotFoundError(f"ARCHX_USR_DIR does not exist: {src}")
        shutil.rmtree(CACHE, ignore_errors=True)
        shutil.copytree(src, CACHE, dirs_exist_ok=True, ignore=shutil.ignore_patterns(".git", ".mozilla", ".cache", "__pycache__", "*.pyc", "*.pyo", "Cache", "cache2"))
    elif CACHE.exists() and (CACHE / ".git").exists():
        run_allowfail("git", _git_dir(), "stash", stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if USR_REF:
            run_allowfail("git", _git_dir(), "fetch", "origin", USR_REF, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            run_allowfail("git", _git_dir(), "checkout", USR_REF, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        r = run_allowfail("git", _git_dir(), "pull", "--rebase", stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if r.returncode != 0:
            warn("cached git pull failed; recloning usr")
            _clone_usr_repo()
    else:
        _clone_usr_repo()

    _sync_usr_tree()
    for p in [HOME / ".git", HOME / "README.md", HOME / "LICENSE"]:
        if p.is_dir():
            shutil.rmtree(p, ignore_errors=True)
        else:
            p.unlink(missing_ok=True)

    post_apply()

def _skip(p):
    name = p.name
    rel = str(p.relative_to(CACHE))
    return (name in ("README.md", "LICENSE")
            or rel.startswith(".git")
            or rel.startswith(".mozilla")
            or rel.startswith(".cache"))


# ── System Setup ─────────────────────────────────────────

PREINSTALL_BANNER = r"""
___________________________
  Hyprland post install   /
_________________________/

"""

FINAL_BANNER = r"""
___________________________
  Hyprland final setup    /
_________________________

"""


def online():
    for host in ("archlinux.org", "github.com", "1.1.1.1"):
        r = run_allowfail("ping", "-c", "1", "-W", "2", host,
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if r.returncode == 0:
            return True
    return False


def _wifi_nmcli():
    run_allowfail("rfkill", "unblock", "wifi", sudo=True,
                  stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    run_allowfail("systemctl", "enable", "--now", "NetworkManager", sudo=True,
                  stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    run_allowfail("nmcli", "radio", "wifi", "on",
                  stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    warn("Scanning networks with nmcli…")
    r = run_allowfail("nmcli", "-t", "-f", "SSID,SECURITY", "device", "wifi", "list",
                      capture_output=True, text=True)
    if r.returncode != 0 or not r.stdout.strip():
        return False

    networks = []
    seen = set()
    for line in r.stdout.strip().splitlines():
        ssid, _, sec = line.partition(":")
        ssid = ssid.replace(r"\:", ":").strip()
        if ssid and ssid not in seen:
            seen.add(ssid)
            networks.append((ssid, sec.strip()))

    if not networks:
        return False

    print(f"\n  {'#':>3}  {'SSID':<30}  {'Security':<15}")
    print(f"  {'─'*3}  {'─'*30}  {'─'*15}")
    for i, (ssid, sec) in enumerate(networks, 1):
        print(f"  {i:>3}  {ssid:<30}  {(sec or 'Open'):<15}")

    try:
        idx = int(input("\n  Select network (0 to skip): ").strip() or "0")
        if idx <= 0 or idx > len(networks):
            return False
    except ValueError:
        return False

    ssid, sec = networks[idx - 1]
    password = getpass.getpass("  Password (empty for open): ") if sec else ""
    ok(f"Connecting to {ssid} …")
    if password:
        r = run_allowfail("nmcli", "device", "wifi", "connect", ssid, "password", password, sudo=True)
    else:
        r = run_allowfail("nmcli", "device", "wifi", "connect", ssid, sudo=True)
    return r.returncode == 0


def _wifi_iwctl():
    run_allowfail("rfkill", "unblock", "wifi", sudo=True,
                  stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    run_allowfail("systemctl", "start", "iwd", sudo=True,
                  stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    print()
    run_allowfail("iwctl", "device", "list")
    dev = input("  Device: ").strip()
    if not dev:
        return False
    run_allowfail("iwctl", "station", dev, "scan")
    run_allowfail("iwctl", "station", dev, "get-networks")
    ssid = input("  SSID: ").strip()
    if not ssid:
        return False
    password = getpass.getpass("  Password (empty for open): ")
    if password:
        r = run_allowfail("iwctl", "--passphrase", password, "station", dev, "connect", ssid)
    else:
        r = run_allowfail("iwctl", "station", dev, "connect", ssid)
    return r.returncode == 0


def wifi_connect():
    """Connect Wi-Fi with nmcli, iwctl, or legacy wifi-menu."""
    if has("nmcli") and _wifi_nmcli():
        ok("Wi-Fi connected")
        return True
    if has("iwctl") and _wifi_iwctl():
        ok("Wi-Fi connected")
        return True
    if has("wifi-menu"):
        return run_allowfail("wifi-menu", sudo=True).returncode == 0
    fail("No Wi-Fi helper found. Install/use NetworkManager, iwd, or wifi-menu.")
    return False


def ensure_network():
    if online():
        ok("Network online")
        return True
    warn("Network offline — opening Wi-Fi setup")
    wifi_connect()
    if online():
        ok("Network online")
        return True
    fail("Still offline; connect first and rerun archx")
    return False


def setup_system():
    """Full system setup — preinstall (live) or final (chroot)."""
    if os.geteuid() != 0:
        # ── Preinstall (live environment) ──
        print(PREINSTALL_BANNER)
        ensure_network()

        warn("Running post-install setup…")
        ensure_deps()
        update_config()
    else:
        # ── Final install (chroot, running as root) ──
        print(FINAL_BANNER)

        user = run_allowfail("logname", capture_output=True, text=True).stdout.strip() or "nobody"
        user_home = Path(f"/home/{user}")

        warn("Set root password")
        run("passwd", "root")

        pos = input("  Layout? [us]: ").strip() or "us"
        run_allowfail("localectl", "set-keymap", "--no-ask-password", pos)
        run_allowfail("localectl", "set-x11-keymap", "--no-ask-password", pos)
        tz = run_allowfail("curl", "-s", "--fail", "https://ipapi.co/timezone",
                           capture_output=True, text=True).stdout.strip()
        if tz:
            run_allowfail("timedatectl", "--no-ask-password", "set-timezone", tz)
        run_allowfail("timedatectl", "--no-ask-password", "set-ntp", "1")
        run_allowfail("localectl", "--no-ask-password", "set-locale",
                      "LANG=en_US.UTF-8", "LC_TIME=en_US.UTF-8")

        if input("  Is laptop? [y/N]: ").strip().lower() == "y":
            ok("Laptop — installing TLP, ACPI …")
            run("pacman", "-S", "--needed", "--noconfirm",
                "sof-firmware", "tlp", "acpi", "acpid")
            tlp_cfg = "/etc/tlp.conf"
            if Path(tlp_cfg).exists():
                for sed_cmd in [
                    r's/^#\(SOUND_POWER_SAVE_ON_AC=\).*/\10/',
                    r's/^#\(START_CHARGE_THRESH_BAT0=\).*/\185/',
                    r's/^#\(STOP_CHARGE_THRESH_BAT0=\).*/\190/',
                    r's/^#\(START_CHARGE_THRESH_BAT1=\).*/\185/',
                    r's/^#\(STOP_CHARGE_THRESH_BAT1=\).*/\190/',
                ]:
                    run_allowfail("sed", "-i", "-E", sed_cmd, tlp_cfg)
            run("systemctl", "enable", "tlp.service")

        gpu = run_allowfail("lspci", capture_output=True, text=True).stdout
        if "NVIDIA" in gpu or "GeForce" in gpu:
            ok("NVIDIA — installing envycontrol")
            if not has("yay"):
                _install_yay()
            if has("yay"):
                run("yay", "-S", "--noconfirm", "--needed", "envycontrol")
                run_allowfail("envycontrol", "-s", "nvidia", "--force-comp")

        run_allowfail("xset", "r", "rate", "560", "25")

        # Cleanup orphans + cache
        orphans = run_allowfail("pacman", "-Qdtq", capture_output=True, text=True).stdout.strip()
        if orphans:
            run("pacman", "-Rns", "--noconfirm", *orphans.splitlines())
        run_allowfail("paccache", "-r")
        run_allowfail("sysctl", "--system")

        run("chown", "-R", f"{user}:{user}", str(user_home))
        run("chmod", "755", str(user_home))

        for f in ["wifi-menu.sh"]:
            (user_home / f).unlink(missing_ok=True)

        ok("All done — rebooting in 5s …")
        time.sleep(5)
        run("reboot")


# ── Menu ────────────────────────────────────────────────

def pick(options, prompt="Select: "):
    try:
        is_tty = os.isatty(sys.stdout.fileno())
    except Exception:
        is_tty = False
    use = has("fzf-tmux") and is_tty
    if use:
        r = subprocess.run(
            ["fzf-tmux", "--prompt", prompt, "-x", "--height", os.environ.get("FZF_TMUX_HEIGHT", "40%"),
             "-m", "--reverse", "--ansi"],
            input="\n".join(options), capture_output=True, text=True)
        return r.stdout.strip() or None

    print()
    for i, o in enumerate(options, 1):
        print(f"  {i}. {o}")
    try:
        c = input(f"\n  {prompt}").strip()
        return options[int(c) - 1]
    except (ValueError, IndexError):
        return None


def run_menu():
    ensure_deps()
    root = True

    while root:
        logo()
        available = SELF.exists()
        has_updates = check_updates()
        if has_updates:
            print()

        if available:
            sel = pick(["Install", "Setup", "Update", "Quit"])
        else:
            sel = pick(["Configs", "Quit"])

        if sel in ("Update", "Configs"):
            try:
                update_config()
            except Exception as e:
                fail(f"Update failed: {e}")
                input("  Press Enter …")
            continue
        if sel == "Setup":
            try:
                setup_system()
            except Exception as e:
                fail(f"Setup failed: {e}")
                input("  Press Enter …")
            continue
        if sel == "Quit":
            return
        if sel != "Install":
            continue

        # Install menu
        while True:
            logo()
            sel = pick(["Services", "Apps", "Back"])
            if sel == "Back":
                break
            if sel == "Services":
                logo()
                sel = pick(["Printers", "Samba", "Back"])
                try:
                    if sel == "Printers":
                        install_printers()
                    elif sel == "Samba":
                        install_samba()
                    elif sel == "Back":
                        continue
                    if sel and sel != "Back":
                        ok("Done")
                        input("  Press Enter …")
                except Exception as e:
                    fail(f"Failed: {e}")
                    input("  Press Enter …")
            elif sel == "Apps":
                logo()
                sel = pick(["Upgrade", "Remap", "Wine", "Ctpv", "Back"])
                try:
                    if sel == "Upgrade":
                        run("yay", "-Syu", "--noconfirm")
                    elif sel == "Remap":
                        install_remap()
                    elif sel == "Wine":
                        install_wine()
                    elif sel == "Ctpv":
                        install_ctpv()
                    elif sel == "Back":
                        continue
                    if sel and sel != "Back":
                        ok("Done")
                        input("  Press Enter …")
                except Exception as e:
                    fail(f"Failed: {e}")
                    input("  Press Enter …")


# ── Entry ───────────────────────────────────────────────

def main():
    global AUTO_YES
    p = argparse.ArgumentParser(description="ArchX — Hyprland toolbox")
    p.add_argument("cmd", nargs="?", choices=["setup", "update", "updates", "wifi"], help="Run setup/update/wifi")
    p.add_argument("--yes", "-y", action="store_true", help="Do not prompt before syncing configs")
    args = p.parse_args()
    AUTO_YES = AUTO_YES or args.yes

    signal.signal(signal.SIGINT, lambda s, f: sys.exit(0))
    signal.signal(signal.SIGTERM, lambda s, f: sys.exit(0))

    try:
        if args.cmd == "updates":
            check_updates_notify()
        elif args.cmd in ("setup", "update"):
            ensure_deps()
            update_config()
        elif args.cmd == "wifi":
            wifi_connect()
        else:
            run_menu()
    except KeyboardInterrupt:
        print()
        sys.exit(0)


if __name__ == "__main__":
    main()
