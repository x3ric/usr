HOME = Path.home()
BIN = HOME / ".local/share/bin"
CACHE = HOME / ".cache/usr"
ARCHX_CACHE = HOME / ".cache/archx"
AUTOSTART = BIN / "autostart"
SELF = BIN / "archx"
USR_REPO = os.environ.get("ARCHX_USR_REPO", "https://github.com/X3ric/usr.git")
PKG_OFFICIAL = os.environ.get("ARCHX_PKG_OFFICIAL", "https://raw.githubusercontent.com/X3ric/ArchX/refs/heads/main/pkg-files/hyprland.txt")
PKG_AUR = os.environ.get("ARCHX_PKG_AUR", "https://raw.githubusercontent.com/X3ric/ArchX/refs/heads/main/pkg-files/aur-pkgs.txt")
USR_REF = os.environ.get("ARCHX_USR_REF", "")
USR_DIR = os.environ.get("ARCHX_USR_DIR", "")
AUTO_YES = os.environ.get("ARCHX_YES", "").lower() in ("1", "yes", "true", "y")
SKIP_PACKAGES = os.environ.get("ARCHX_SKIP_PACKAGES", "").lower() in ("1", "yes", "true", "y")

ARCHX_ZSHENV_TEXT = 'export ZDOTDIR="$HOME/.local/zsh"\nexport PATH="$HOME/.local/share/bin:$HOME/.local/bin:$PATH"\n'
ARCHX_COMPAT_ZSHRC = '# ArchX compatibility loader.\n# Some older installs/global zshenv files pointed ZDOTDIR at ~/.config/zsh.\n# Keep that path working, but always load the real config from ~/.local/zsh.\nexport ZDOTDIR="$HOME/.local/zsh"\nexport PATH="$HOME/.local/share/bin:$HOME/.local/bin:$PATH"\n[ -f "$HOME/.local/zsh/.zshrc" ] && source "$HOME/.local/zsh/.zshrc"\n'
ARCHX_HOME_ZSHRC = '# ArchX zsh compatibility loader.\nexport ZDOTDIR="$HOME/.local/zsh"\nexport PATH="$HOME/.local/share/bin:$HOME/.local/bin:$PATH"\n[ -f "$ZDOTDIR/.zshrc" ] && source "$ZDOTDIR/.zshrc"\n'
ARCHX_COMPAT_ZPROFILE = '# ArchX compatibility profile loader.\nexport ZDOTDIR="$HOME/.local/zsh"\n[ -f "$HOME/.local/zsh/.zprofile" ] && source "$HOME/.local/zsh/.zprofile"\n'

# Prefer usr-shipped tools first (papirus-folders, walset, gtkset, fzf-preview, etc.).
os.environ["PATH"] = f"{BIN}:{os.environ.get('PATH', '')}"

GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
RESET = "\033[0m"


# ── Helpers ─────────────────────────────────────────────

def ok(msg):
    print(f"  [{GREEN}✓{RESET}] {msg}")

def warn(msg):
    print(f"  [{YELLOW}!{RESET}] {msg}")

def fail(msg):
    print(f"  [{RED}✗{RESET}] {msg}")

def has(name):
    return shutil.which(name) is not None


def _cmd(args, sudo=False):
    cmd = list(args)
    if sudo and os.geteuid() != 0:
        cmd.insert(0, "sudo")
    return cmd


def run(*args, sudo=False, **kw):
    return subprocess.run(_cmd(args, sudo=sudo), check=True, **kw)


def run_allowfail(*args, sudo=False, **kw):
    return subprocess.run(_cmd(args, sudo=sudo), **kw)


class Spinner:
    def __init__(self, msg):
        self.msg = msg
        self._run = False
        self._th = None

    def start(self):
        self._run = True
        self._th = threading.Thread(target=self._spin, daemon=True)
        self._th.start()

    def _spin(self):
        chars = "|/-\\"
        i = 0
        while self._run:
            sys.stdout.write(f"\r  [{chars[i % 4]}] {self.msg}")
            sys.stdout.flush()
            time.sleep(0.12)
            i += 1

    def stop(self, success=True):
        self._run = False
        if self._th:
            self._th.join()
        mark = f"{GREEN}✓{RESET}" if success else f"{RED}✗{RESET}"
        sys.stdout.write(f"\r  [{mark}] {self.msg}\n")
        sys.stdout.flush()


