    (wal_cache / "colors-fzf.zsh").write_text(fzf_text)

    kitty_dir = HOME / ".config/kitty"
    kitty_dir.mkdir(parents=True, exist_ok=True)
    (kitty_dir / "colors.conf").write_text(kitty_text)

    # Keep the default Nature palette deterministic; walset can be run manually to pick another wallpaper.
    wlogout = HOME / ".config/wlogout"
    wlogout.mkdir(parents=True, exist_ok=True)
    _write_file(wlogout / "style.css", """* { background-image: none; box-shadow: none; font-family: FiraCode Nerd Font, Fira Code, monospace; font-size: 16px; }
window { background-color: rgba(11, 11, 11, 0.74); }
button { color: #c0acd1; background-color: rgba(72, 83, 74, 0.50); border: 2px solid rgba(192, 172, 209, 0.22); border-radius: 18px; background-repeat: no-repeat; background-position: center; background-size: 30%; margin: 14px; min-width: 140px; min-height: 120px; transition: 120ms ease-in-out; }
