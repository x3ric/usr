#!/usr/bin/env bash
set -u
run() {
  local name="$1"; shift || true
  pgrep -x "$name" >/dev/null 2>&1 || "$name" "$@" >/dev/null 2>&1 &
}

run mpd
run aria2c
run nm-applet
run blueman-applet
command -v xfce4-clipman >/dev/null 2>&1 && run xfce4-clipman
command -v libinput-gestures-setup >/dev/null 2>&1 && libinput-gestures-setup start >/dev/null 2>&1 || true
command -v input-remapper-control >/dev/null 2>&1 && input-remapper-control --command autoload >/dev/null 2>&1 &
command -v /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1 && /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 >/dev/null 2>&1 &
command -v mpDris2 >/dev/null 2>&1 && mpDris2 >/dev/null 2>&1 &
