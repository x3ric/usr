#!/usr/bin/env python3
import os, shutil, subprocess, sys
colors = os.path.expanduser('~/.cache/wal/colors')
cmd = shutil.which('papirus-folders')
if not cmd or not os.path.exists(colors):
    sys.exit(0)
try:
    lines = [x.strip() for x in open(colors) if x.strip()]
    color = lines[4] if len(lines) > 4 else '#658B5F'
    r, g, b = [int(color[i:i+2], 16) for i in (1, 3, 5)]
except Exception:
    sys.exit(0)
palette = {
    'blue': '#0000FF', 'cyan': '#00FFFF', 'green': '#00FF00', 'violet': '#FF00FF',
    'yellow': '#FFFF00', 'orange': '#FFAA00', 'red': '#FF0000', 'black': '#000000'
}
def dist(hexv):
    return sum((int(hexv[i:i+2], 16) - c) ** 2 for i, c in zip((1, 3, 5), (r, g, b)))
name = min(palette, key=lambda k: dist(palette[k]))
subprocess.run([cmd, '-C', name], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
